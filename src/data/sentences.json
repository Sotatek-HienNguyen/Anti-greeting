[\n  { \"id\": 1, \"vn\": \"Xin ch\u00e0o, t\u00ean t\u00f4i l\u00e0 John.\", \"en\": [\"Hello, my name is John.\", \"Hi, I am John.\"] },\n  { \"id\": 2, \"vn\": \"B\u1ea1n kh\u1ecfe kh\u00f4ng?\", \"en\": [\"How are you?\", \"How's it going?\", \"How are you doing?\"] },\n  { \"id\": 3, \"vn\": \"T\u00f4i r\u1ea5t vui \u0111\u01b0\u1ee3c g\u1eb7p b\u1ea1n.\", \"en\": [\"I am very happy to meet you.\", \"Nice to meet you.\", \"Pleased to meet you.\"] },\n  { \"id\": 4, \"vn\": \"B\u1ea1n l\u00e0m ngh\u1ec1 g\u00ec?\", \"en\": [\"What do you do?\", \"What is your job?\", \"What's your occupation?\"] },\n  { \"id\": 5, \"vn\": \"T\u00f4i \u0111ang t\u00ecm m\u1ed9t qu\u00e1n c\u00e0 ph\u00ea g\u1ea7n \u0111\u00e2y.\", \"en\": [\"I am looking for a coffee shop nearby.\", \"I'm searching for a cafe around here.\"] },\n  { \"id\": 6, \"vn\": \"M\u1ea5y gi\u1edd r\u1ed3i?\", \"en\": [\"What time is it?\", \"Do you have the time?\", \"What's the time?\"] },\n  { \"id\": 7, \"vn\": \"C\u00e1i n\u00e0y gi\u00e1 bao nhi\u00eau?\", \"en\": [\"How much is this?\", \"What's the price of this?\", \"How much does this cost?\"] },\n  { \"id\": 8, \"vn\": \"H\u00e3y gi\u1eef li\u00ean l\u1ea1c nh\u00e9.\", \"en\": [\"Let's keep in touch.\", \"Keep in touch.\", \"Stay in contact.\"] },\n  { \"id\": 9, \"vn\": \"T\u1ed1i nay b\u1ea1n c\u00f3 r\u1ea3nh kh\u00f4ng?\", \"en\": [\"Are you free tonight?\", \"Are you available this evening?\"] },\n  { \"id\": 10, \"vn\": \"T\u00f4i kh\u00f4ng hi\u1ec3u b\u1ea1n \u0111ang n\u00f3i g\u00ec.\", \"en\": [\"I don't understand what you are saying.\", \"I don't get what you're saying.\"] }\n]\n